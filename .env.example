# =============================================================================
# Docker compose
# =============================================================================
POSTGRES_DB=hotels
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# =============================================================================
# База данных
# =============================================================================
POSTGRES_PORT=5432
POSTGRES_HOST=postgres
DATABASE_DSN=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# =============================================================================
# Авторизация
# =============================================================================
JWT_SECRET_KEY=secret

# =============================================================================
# Redis
# =============================================================================
# REDIS_PASSWORD нужен сервису redis в docker-compose (--requirepass); в REDIS_URL подставляется через ${...} (pydantic-settings / dotenv).
REDIS_PASSWORD=change_me_strong_password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0
# =============================================================================
# OTHERS
# =============================================================================
MODE=LOCAL